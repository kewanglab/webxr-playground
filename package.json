    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
